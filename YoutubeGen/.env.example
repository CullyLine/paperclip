# xAI (Grok) API key for caption generation and scene matching
XAI_API_KEY=xai-your-key-here

# Optional: Reddit API credentials for trend discovery
# REDDIT_CLIENT_ID=your-client-id
# REDDIT_CLIENT_SECRET=your-client-secret

# Optional: X/Twitter bearer token for trend discovery
# X_BEARER_TOKEN=your-bearer-token

# YouTube Upload - OAuth2 credentials (from Google Cloud Console)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# YouTube Upload - encryption key for stored refresh token
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# YOUTUBE_TOKEN_KEY=your-hex-key
