# Auto detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts (must not have CRLF or they break on Linux/Mac)
*.sh text eol=lf

# Force LF for other script/config files that may be parsed
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.blend binary
*.blend1 binary
